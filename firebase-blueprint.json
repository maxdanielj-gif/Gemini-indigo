        },
        {
          "type": "write",
          "condition": "request.auth != null && request.auth.uid == userId"
        }
      ]
    },
    {
      "name": "indigo_kb_manifests",
      "route": "indigo_kb_manifests/{userId}",
      "description": "User knowledge base manifests.",
      "fields": [],
      "rules": [
        {
          "type": "read",
