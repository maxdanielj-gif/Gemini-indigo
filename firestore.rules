rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // indigo_backups collection
    match /indigo_backups/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // indigo_gallery_manifests collection
    match /indigo_gallery_manifests/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // indigo_kb_manifests collection
    match /indigo_kb_manifests/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
